#!/bin/bash


package() {
  hpack
  hpack docs
  hpack demo
}

watch() {
  ghcid -c "cabal repl demo lib:hyperbole" -T App.run -W --reload=./client/dist/hyperbole.js
}

client() {
  cd client
  npm run dev &
  npm run check
}

# run tests once (so we don't forget!)
cabal test

(trap 'kill 0' SIGINT; client & package && watch)
