{
  "compilerOptions": {
    "outDir": "./dist/",
    "sourceMap": true,
    "noImplicitAny": true,
    "module": "ES2020",
    "target": "ES2020",
    "lib": ["ES2020","DOM"],
    "allowJs": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "strict": true
    // "skipLibCheck": true
    /*"declarationMap": true*/
  },
  "include": [
    "./src/**/*",
    "./declarations.d.ts"
  ]
}
